# ============================================================
# Fillando — Master Environment Template
# ============================================================
# Copy this file to /.env in the meta-repo root, fill in real
# values, then run `bash scripts/sync-env.sh` to distribute
# to child repos.
#
# NEVER commit .env files with real secrets.
# ============================================================

# === BEGIN COMMON ===
NODE_ENV=development
# === END COMMON ===

# === BEGIN BACKEND ===

# --- App ---
PORT=4000
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:9000

# --- Database (MongoDB) ---
DATABASE_URL=mongodb://fillando_user:fillando_pass@localhost:27017/fillando_dev?authSource=admin

# --- JWT ---
JWT_SECRET=CHANGE_ME_min_10_chars
JWT_EXPIRATION=15
ACCSESS_TOKEN_NAME=access_token

REFRESH_JWT_SECRET=CHANGE_ME_min_10_chars_different
REFRESH_JWT_EXPIRATION=10080
REFRESH_TOKEN_NAME=refresh_token

# --- Password ---
PASSWORD_PEPPER=CHANGE_ME_min_16_chars_random

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# --- AWS S3 ---
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=fillando-uploads
AWS_S3_PUBLIC_URL=https://fillando-uploads.s3.eu-central-1.amazonaws.com

# --- Nova Post ---
NOVA_POS_API_KEY=your-nova-post-api-key

# --- Email (Resend) ---
RESEND_API_KEY=re_your_resend_api_key
SERVICE_EMAIL=service@fillando.com
ALLOW_EMAIL_SENDING=false

# === END BACKEND ===

# === BEGIN FRONTEND ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:9000
# === END FRONTEND ===
